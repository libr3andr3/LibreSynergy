# Secrets — real values never get committed; only the *.example templates do.
secrets/*.env
secrets/spaces.json
!secrets/*.example

# Runtime state and backups
data/
backups/
*.log

# Generated brand tokens (produced by apply-branding.sh)
www/brand/tokens.css

# Operator-supplied local config
libresynergy.env

# OS / editor cruft
.DS_Store
*.swp

# Runtime-installed deps (tracker unit installs on first boot)
apps/*/node_modules/

__pycache__/
*.pyc

# Mesh identity material — node keys / passports / rosters are generated at
# runtime by attest.py / agentfacts.py / content_sign.py and are never
# committed (the demos and tests write to tempdirs; these guard the repo dir).
mesh/*.key
mesh/*.pub
mesh/*.facts.json
mesh/*.roster

# Rendered brand outputs — generated from the *.template.* sources by
# apply-branding.sh (run via `ls init` / `ls brand`). Only templates are tracked.
www/index.html
www/robots.txt
www/sitemap.xml
www/app/index.html
www/app/manifest.webmanifest
www/chat/config.json
