# Branding configuration for libresynergy
# Generated by bootstrap — edit to customize your community's appearance

branding:
  # Community name (shown in page titles, headers, emails)
  community_name: "{{ community_name }}"

  # Logo — URL or base64-encoded image (SVG or PNG)
  # Replace with your own logo URL or leave blank for text-only
  logo_url: ""

  # Primary color (hex, used in buttons, links, headers)
  primary_color: "#4F46E5"     # Indigo

  # Secondary color (hex, used in accents, highlights)
  secondary_color: "#7C3AED"   # Violet

  # Background color
  background_color: "#0F172A"  # Dark slate

  # Text color
  text_color: "#F8FAFC"        # Light gray

  # Font family
  font_family: "Inter, system-ui, sans-serif"

  # Favicon URL
  favicon_url: ""

# These values are applied to:
#   - Authentik flows (login, registration pages)
#   - Element Web (via config.json)
#   - Jitsi Meet (via interface_config.js)
#   - Frappe LMS (via site config)
#   - Nginx error pages
