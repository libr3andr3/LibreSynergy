# Generated by libresynergy bootstrap
# Community: {{ community_name }}
# Domain: {{ domain }}

services:
  # ============================================================
  # Database & Cache
  # ============================================================
  postgres:
    image: postgres:16-alpine
    environment:
      POSTGRES_USER: libresynergy
      POSTGRES_PASSWORD: {{ secrets.postgres_password }}
      POSTGRES_DB: libresynergy
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U libresynergy"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    command: redis-server --requirepass {{ secrets.redis_password }}
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "--raw", "incr", "ping"]
      interval: 5s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  # ============================================================
  # SSO — Authentik
  # ============================================================
  authentik-server:
    image: ghcr.io/goauthentik/server:latest
    command: server
    environment:
      AUTHENTIK_SECRET_KEY: {{ secrets.authentik_secret }}
      AUTHENTIK_POSTGRESQL__HOST: postgres
      AUTHENTIK_POSTGRESQL__USER: libresynergy
      AUTHENTIK_POSTGRESQL__PASSWORD: {{ secrets.postgres_password }}
      AUTHENTIK_POSTGRESQL__NAME: libresynergy
      AUTHENTIK_REDIS__HOST: redis
      AUTHENTIK_REDIS__PASSWORD: {{ secrets.redis_password }}
      AUTHENTIK_ERROR_REPORTING__ENABLED: "false"
      AUTHENTIK_EMAIL__HOST: ""
    volumes:
      - authentik_media:/media
      - authentik_custom_templates:/templates
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: unless-stopped

  authentik-worker:
    image: ghcr.io/goauthentik/server:latest
    command: worker
    environment:
      AUTHENTIK_SECRET_KEY: {{ secrets.authentik_secret }}
      AUTHENTIK_POSTGRESQL__HOST: postgres
      AUTHENTIK_POSTGRESQL__USER: libresynergy
      AUTHENTIK_POSTGRESQL__PASSWORD: {{ secrets.postgres_password }}
      AUTHENTIK_POSTGRESQL__NAME: libresynergy
      AUTHENTIK_REDIS__HOST: redis
      AUTHENTIK_REDIS__PASSWORD: {{ secrets.redis_password }}
      AUTHENTIK_ERROR_REPORTING__ENABLED: "false"
    volumes:
      - authentik_media:/media
      - authentik_custom_templates:/templates
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    restart: unless-stopped

  # ============================================================
  # libresynergy API — glue layer
  # ============================================================
  api:
    build:
      context: .
      dockerfile: docker/api/Dockerfile
    environment:
      DATABASE_URL: postgresql://libresynergy:{{ secrets.postgres_password }}@postgres:5432/libresynergy
      REDIS_URL: redis://:{{ secrets.redis_password }}@redis:6379
      AUTHENTIK_URL: https://auth.{{ domain }}
      AUTHENTIK_API_TOKEN: {{ secrets.authentik_secret }}
      INSTANCE_UUID: {{ secrets.instance_uuid }}
      FEDERATION_SECRET: {{ secrets.federation_secret }}
      ADMIN_API_KEY: {{ secrets.api_admin_key }}
{% if btcpay_url is defined and btcpay_url %}
      BTCPAY_URL: {{ btcpay_url }}
{% endif %}
{% if btcpay_key is defined and btcpay_key %}
      BTCPAY_API_KEY: {{ btcpay_key }}
{% endif %}
{% if stripe_key is defined and stripe_key %}
      STRIPE_SECRET_KEY: {{ stripe_key }}
{% endif %}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      authentik-server:
        condition: service_started
    restart: unless-stopped

  # ============================================================
  # Frappe LMS — courses & certificates
  # ============================================================
  frappe:
    image: frappe/frappe-lms:latest
    environment:
      DB_HOST: postgres
      DB_PORT: "5432"
      SITE_NAME: {{ domain }}
      ADMIN_EMAIL: {{ admin_email }}
      OIDC_CLIENT_ID: {{ authentik_frappe_client_id }}
      OIDC_CLIENT_SECRET: {{ authentik_frappe_client_secret }}
      OIDC_AUTH_URL: https://auth.{{ domain }}/application/o/authorize/
      OIDC_TOKEN_URL: https://auth.{{ domain }}/application/o/token/
      OIDC_USERINFO_URL: https://auth.{{ domain }}/application/o/userinfo/
    volumes:
      - frappe_sites:/home/frappe/frappe-bench/sites
      - ./frappe-common-site-config.json:/home/frappe/frappe-bench/sites/common_site_config.json:ro
    depends_on:
      postgres:
        condition: service_healthy
      authentik-server:
        condition: service_started
    restart: unless-stopped

  # ============================================================
  # Matrix Synapse — federated chat server
  # ============================================================
  matrix:
    image: matrixdotorg/synapse:latest
    environment:
      SYNAPSE_SERVER_NAME: chat.{{ domain }}
      SYNAPSE_REPORT_STATS: "no"
      SYNAPSE_OIDC_ENABLED: "true"
      SYNAPSE_OIDC_ISSUER: https://auth.{{ domain }}/application/o/matrix/
      SYNAPSE_OIDC_CLIENT_ID: {{ authentik_matrix_client_id }}
      SYNAPSE_OIDC_CLIENT_SECRET: {{ authentik_matrix_client_secret }}
    volumes:
      - matrix_data:/data
      - ./homeserver.yaml:/data/homeserver.yaml:ro
    depends_on:
      postgres:
        condition: service_healthy
      authentik-server:
        condition: service_started
    restart: unless-stopped

  # ============================================================
  # Element Web — Matrix web client
  # ============================================================
  element:
    image: vectorim/element-web:latest
    environment:
      ELEMENT_SERVER_NAME: chat.{{ domain }}
    volumes:
      - ./element-config.json:/app/config.json:ro
    depends_on:
      - matrix
    restart: unless-stopped

  # ============================================================
  # Jitsi Meet — video conferencing
  # ============================================================
  jitsi-web:
    image: jitsi/web:latest
    environment:
      JITSI_PUBLIC_URL: https://meet.{{ domain }}
      JITSI_JWT_APP_ID: libresynergy
      JITSI_JWT_SECRET: {{ secrets.jitsi_jwt_secret }}
    volumes:
      - ./jitsi-config.js:/config/config.js:ro
      - ./jitsi-interface-config.js:/config/interface_config.js:ro
    ports:
      - "10000:10000/udp"
    depends_on:
      - prosody
      - jicofo
    restart: unless-stopped

  prosody:
    image: jitsi/prosody:latest
    environment:
      JITSI_AUTH_TYPE: jwt
      JITSI_JWT_APP_ID: libresynergy
      JITSI_JWT_SECRET: {{ secrets.jitsi_jwt_secret }}
    volumes:
      - ./prosody.cfg.lua:/config/prosody.cfg.lua:ro
    restart: unless-stopped

  jicofo:
    image: jitsi/jicofo:latest
    environment:
      JITSI_JWT_APP_ID: libresynergy
      JITSI_JWT_SECRET: {{ secrets.jitsi_jwt_secret }}
    depends_on:
      - prosody
    restart: unless-stopped

  jvb:
    image: jitsi/jvb:latest
    environment:
      JITSI_JVB_ADVERTISE_IPS: {{ domain }}
    ports:
      - "10000:10000/udp"
    depends_on:
      - prosody
    restart: unless-stopped

  # ============================================================
  # Reverse Proxy — Nginx
  # ============================================================
  nginx:
    image: nginx:alpine
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./well-known:/usr/share/nginx/html/.well-known:ro
      - nginx_certs:/etc/nginx/certs
    depends_on:
      - authentik-server
      - api
    restart: unless-stopped

volumes:
  postgres_data:
  redis_data:
  authentik_media:
  authentik_custom_templates:
  nginx_certs:
  frappe_sites:
  matrix_data:
