# Matrix Synapse homeserver configuration
# Generated by libresynergy — config-only, no source modifications

server_name: "chat.{{ domain }}"
pid_file: /data/homeserver.pid

# --- Listeners ---
listeners:
  - port: 8008
    tls: false
    type: http
    x_forwarded: true
    resources:
      - names: [client, federation]
        compress: false

# --- Database ---
database:
  name: psycopg2
  args:
    user: libresynergy
    password: {{ secrets.postgres_password }}
    host: postgres
    database: libresynergy
    cp_min: 5
    cp_max: 10

# --- Event storage ---
event_cache_size: "10K"

# --- Logging ---
log_config: "/data/log.yaml"

# --- Media ---
media_store_path: "/data/media_store"
max_upload_size: "50M"

# --- Registration ---
enable_registration: false
registration_requires_token: true

# --- SSO / OIDC ---
oidc_providers:
  - idp_id: authentik
    idp_name: "SSO"
    idp_icon: "mxc://chat.{{ domain }}/authentik-icon"
    discover: true
    issuer: "https://auth.{{ domain }}/application/o/matrix/"
    client_id: "{{ authentik_matrix_client_id }}"
    client_secret: "{{ authentik_matrix_client_secret }}"
    scopes: ["openid", "profile", "email"]
    authorization_endpoint: "https://auth.{{ domain }}/application/o/authorize/"
    token_endpoint: "https://auth.{{ domain }}/application/o/token/"
    userinfo_endpoint: "https://auth.{{ domain }}/application/o/userinfo/"
    user_mapping_provider:
      config:
        localpart_template: "{{ '{{ user.sub }}' }}"
        display_name_template: "{{ '{{ user.name }}' }}"
        email_template: "{{ '{{ user.email }}' }}"

# --- Federation ---
allow_federation: true
federation_domain_whitelist: []
federation_ip_range_blacklist: []

# --- Room defaults ---
default_room_version: "10"
enable_room_list_search: true

# --- Rate limiting ---
rc_message:
  per_second: 0.2
  burst_count: 10
rc_registration:
  per_second: 0.1
  burst_count: 3

# --- Presence ---
presence:
  enabled: true

# --- Retention ---
retention:
  enabled: false

# --- Secrets ---
macaroon_secret_key: "{{ secrets.matrix_macaroon_secret }}"
form_secret: "{{ secrets.matrix_form_secret }}"
registration_shared_secret: "{{ secrets.matrix_registration_secret }}"

# --- TURN / STUN ---
turn_uris: []
turn_shared_secret: ""
turn_user_lifetime: "1h"
turn_allow_guests: true

# --- URL previews ---
url_preview_enabled: true
url_preview_ip_range_blacklist: []

# --- Admin ---
admin_contact: "mailto:{{ admin_email }}"

# --- Experimental ---
experimental_features:
  msc3861:
    enabled: false
