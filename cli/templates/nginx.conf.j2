# Generated by libresynergy bootstrap
# Community: {{ community_name }}
# Domain: {{ domain }}

events {
    worker_connections 1024;
}

http {
    include       /etc/nginx/mime.types;
    default_type  application/octet-stream;

    sendfile        on;
    keepalive_timeout  65;

    # ============================================================
    # Authentik — SSO on auth subdomain
    # ============================================================
    server {
        listen 443 ssl;
        server_name auth.{{ domain }};

        ssl_certificate     /etc/nginx/certs/auth.{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/auth.{{ domain }}.key;

        location / {
            proxy_pass http://authentik-server:9000;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    # ============================================================
    # Frappe LMS — learning.{{ domain }}
    # ============================================================
    server {
        listen 443 ssl;
        server_name learn.{{ domain }};

        ssl_certificate     /etc/nginx/certs/learn.{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/learn.{{ domain }}.key;

        client_max_body_size 50m;

        location / {
            proxy_pass http://frappe:8000;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    # ============================================================
    # Matrix Synapse + Element — chat.{{ domain }}
    # ============================================================
    server {
        listen 443 ssl;
        server_name chat.{{ domain }};

        ssl_certificate     /etc/nginx/certs/chat.{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/chat.{{ domain }}.key;

        # Element Web static client
        location / {
            proxy_pass http://element:80;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }

        # Matrix client-server API
        location /_matrix {
            proxy_pass http://matrix:8008;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }

    # ============================================================
    # Matrix Federation — port 8448
    # ============================================================
    server {
        listen 8448 ssl;
        server_name chat.{{ domain }};

        ssl_certificate     /etc/nginx/certs/chat.{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/chat.{{ domain }}.key;

        location / {
            proxy_pass http://matrix:8008;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }
    }

    # ============================================================
    # Jitsi Meet — meet.{{ domain }}
    # ============================================================
    server {
        listen 443 ssl;
        server_name meet.{{ domain }};

        ssl_certificate     /etc/nginx/certs/meet.{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/meet.{{ domain }}.key;

        location / {
            proxy_pass http://jitsi-web:80;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }

        location /xmpp-websocket {
            proxy_pass http://prosody:5280;
            proxy_http_version 1.1;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
            proxy_set_header Host $host;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        }
    }

    # ============================================================
    # libresynergy API — api.{{ domain }}
    # ============================================================
    server {
        listen 443 ssl;
        server_name api.{{ domain }};

        ssl_certificate     /etc/nginx/certs/api.{{ domain }}.crt;
        ssl_certificate_key /etc/nginx/certs/api.{{ domain }}.key;

        location / {
            proxy_pass http://api:5000;
            proxy_set_header Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
        }
    }
}
