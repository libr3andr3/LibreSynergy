-- Prosody XMPP server configuration for Jitsi Meet
-- Generated by libresynergy — config-only, no source modifications
-- JWT authentication against Authentik

plugin_paths = { "/prosody-plugins/", "/prosody-plugins-custom/" }

-- Domain config
VirtualHost "meet.{{ domain }}"
    authentication = "token"
    app_id = "libresynergy"
    app_secret = "{{ secrets.jitsi_jwt_secret }}"

    -- Allow creation of rooms
    allow_empty_token = false

    -- External JWKS validation (Authentik)
    -- Uncomment when Authentik JWKS endpoint is ready:
    -- asap_accepted_issuers = { "authentik" }
    -- asap_jwks_url = "https://auth.{{ domain }}/application/o/jitsi/jwks/"

    ssl = {
        key = "/config/certs/meet.{{ domain }}.key";
        certificate = "/config/certs/meet.{{ domain }}.crt";
    }

    modules_enabled = {
        "bosh";
        "pubsub";
        "ping";
        "speakerstats";
        "turncredentials";
        "conference_duration";
        "presence";
    }

    -- Room settings
    speakerstats_component = "speakerstats.meet.{{ domain }}"
    conference_duration_component = "conferenceduration.meet.{{ domain }}"

Component "conference.meet.{{ domain }}" "muc"
    storage = "memory"
    modules_enabled = {
        "muc_meeting_id";
        "muc_domain_mapper";
        "polls";
        "muc_rate_limit";
        "token_verification";
        "token_affiliation";
    }
    muc_room_locking = false
    muc_room_default_public_jids = true

    -- Token-based room affiliation
    -- Maps JWT claims to XMPP affiliations (owner, admin, member)
    token_affiliation_enabled = true

Component "focus.meet.{{ domain }}"
    component_secret = "{{ secrets.jitsi_jwt_secret }}"

Component "speakerstats.meet.{{ domain }}" "speakerstats_component"
    muc_component = "conference.meet.{{ domain }}"

Component "conferenceduration.meet.{{ domain }}" "conference_duration_component"
    muc_component = "conference.meet.{{ domain }}"
