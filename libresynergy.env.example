# ============================================================================
#  LibreSynergy — one config to brand & deploy your whole community.
#  Copy to  libresynergy.env,  edit,  then:  ./bin/ls init  &&  ./bin/ls up
#  Values here are shell-sourced, so ${VAR} expansion works (subdomains derive
#  from LS_BASE_DOMAIN automatically — you usually only set LS_BASE_DOMAIN).
# ============================================================================

# ---- Identity / branding -----------------------------------------------------
LS_BRAND_NAME="Yaya"
LS_BRAND_TAGLINE="A self-hosted community"
LS_BASE_DOMAIN="yaya.sh"
LS_ADMIN_EMAIL="andre@yaya.sh"
LS_POWERED_BY="LibreSynergy"                 # footer credit; empty to hide
LS_PROJECT_NAME="libresynergy"               # docker compose project name

# Default UI language for the whole stack: en | es | fr. Per-visitor overridable
# via the in-page EN/ES/FR switcher (?lang=) and the browser's Accept-Language;
# also seeds the default locale of Authentik, the LMS, Jitsi, Element & checkout.
LS_DEFAULT_LANG="en"

# Brand palette (fed to the app shell, landing, checkout, emails)
LS_COLOR_BRAND="#7c6cff"
LS_COLOR_ACCENT="#ffc15e"
LS_COLOR_INK="#0b0b12"
LS_BRAND_DIR="./www/brand"                   # logo.svg, favicon.ico, apple-touch-icon.png, icon-512.png

# ---- Subdomains (each needs one DNS A record -> your relay's public IP) ------
# Derived from LS_BASE_DOMAIN by default; override only for non-standard hosts.
LS_APP="app.${LS_BASE_DOMAIN}"               # the unified installable app shell
LS_AUTH="auth.${LS_BASE_DOMAIN}"             # SSO / login (Authentik)
LS_CHAT="chat.${LS_BASE_DOMAIN}"             # Matrix web client
LS_MATRIX="matrix.${LS_BASE_DOMAIN}"         # Matrix homeserver (Synapse)
LS_LEARN="learn.${LS_BASE_DOMAIN}"           # Classroom (Frappe LMS)
LS_MEET="meet.${LS_BASE_DOMAIN}"             # Webinars (Jitsi)
LS_LIVE="live.${LS_BASE_DOMAIN}"             # Livestreams (OwnCast, optional)
LS_PREMIUM="premium.${LS_BASE_DOMAIN}"       # checkout / account (payments bridge)
LS_PAY="btcpay.${LS_BASE_DOMAIN}"            # crypto checkout (BTCPay, optional)
LS_ADMIN="admin.${LS_BASE_DOMAIN}"           # admin dashboard (optional)
LS_TRACKER="tracker.${LS_BASE_DOMAIN}"       # WebTorrent tracker for course VOD (optional)

# ---- Infrastructure / portability -------------------------------------------
LS_DATA_DIR="./data"                         # all app state lives here (back this up)
LS_WWW_DIR="./www"                           # static assets: brand/, app/, chat/config.json
LS_SECRETS_DIR="./secrets"                    # *.env secret files (chmod 600, gitignored)
LS_TZ="UTC"

# WireGuard relay topology (the VeryPowerful pattern). Caddy binds LS_WG_IP on
# the node; the public VPS relay is LS_RELAY_WG_IP and forwards to it.
LS_WG_IP="10.0.0.2"                          # this node's WireGuard address
LS_RELAY_WG_IP="10.0.0.1"                     # the VPS relay's WireGuard address
LS_RELAY_PUBLIC_IP="103.89.12.145"           # the VPS public IP (used in DNS A records)

# SSH aliases ./bin/ls-route uses to reach each box (match your ~/.ssh/config).
LS_NODE_SSH="node"                            # the box running Caddy + the apps
LS_RELAY_SSH="vps"                            # the public VPS relay (root)

# STUN for Jitsi (kept off Google by default to honor the no-Big-Tech promise).
LS_STUN_SERVERS="meet-jit-si-turnrelay.jitsi.net:443"

# ---- Behavior toggles --------------------------------------------------------
LS_ENABLE_REGISTRATION="false"               # Matrix open sign-up; false = SSO-gated (recommended)

# ---- Membership tiers (keyed off Authentik groups) --------------------------
LS_PREMIUM_PRICE_USD="20"
LS_FREE_GROUP="members"
LS_PREMIUM_GROUP="premium"

# ---- Minecraft PoC (profile: games) -----------------------------------------
MC_MEMORY="2G"
MC_ONLINE_MODE="TRUE"
