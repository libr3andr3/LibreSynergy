{#
  home-caddy-site.j2 — reusable Caddy vhost block for LibreSynergy.
  Render one block per extra service and append it to the edge Caddyfile.

  Variables:
    HOST   (required)  full hostname, e.g. chat.example.org
    PORT   (required)  loopback port from the LibreSynergy port map, e.g. 8500
    WG_IP  (optional)  WireGuard bind IP; defaults to 10.0.0.2 (LS_WG_IP)

  Assumes the (secure_headers) snippet from the main Caddyfile is in scope.
  {remote_host} is a Caddy runtime placeholder, not a Jinja variable.
#}
{{HOST}} {
    bind {{ WG_IP | default('10.0.0.2') }}
    import secure_headers
    reverse_proxy 127.0.0.1:{{PORT}} {
        header_up X-Forwarded-For {remote_host}
    }
}
