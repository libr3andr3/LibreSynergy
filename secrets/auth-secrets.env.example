# LibreSynergy — authentik secrets
# Copy to ${LS_SECRETS_DIR}/auth-secrets.env, fill in real values, chmod 600.
#
# IMPORTANT: POSTGRES_PASSWORD and AUTHENTIK_POSTGRESQL__PASSWORD must be the
# SAME value — the first initializes the Postgres user on first boot, the
# second is what authentik uses to connect to it.

# authentik signing/session secret. Rotating it invalidates all sessions.
# generate: openssl rand -hex 50
AUTHENTIK_SECRET_KEY=REPLACE_WITH_openssl_rand_hex_50

# Password for the "authentik" Postgres user (set on first initialization).
# generate: openssl rand -hex 50
POSTGRES_PASSWORD=REPLACE_WITH_openssl_rand_hex_50

# Must be IDENTICAL to POSTGRES_PASSWORD above.
# generate: openssl rand -hex 50 (reuse the same value as POSTGRES_PASSWORD)
AUTHENTIK_POSTGRESQL__PASSWORD=REPLACE_WITH_SAME_VALUE_AS_POSTGRES_PASSWORD
