# LibreSynergy — Authentik API credentials (used by the payments profile:
# payments-bridge, membership-sync, events call the Authentik API to move users
# in/out of the members group). This is DIFFERENT from auth-secrets.env, which
# holds Authentik's own DB/secret-key. Copy to ${LS_SECRETS_DIR}/authentik.env,
# fill in, chmod 600.

# Base URL of your Authentik instance (internal is fine on the node).
AUTHENTIK_URL=http://127.0.0.1:8300

# A non-expiring API token for a service account with permission to manage group
# membership. Create it in Authentik: Directory → Tokens.
AUTHENTIK_TOKEN=REPLACE_WITH_authentik_service_account_token
