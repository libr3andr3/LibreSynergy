# bridge.env — payments-bridge webhook verification secrets
# Copy to ${LS_SECRETS_DIR}/bridge.env and fill in real values. chmod 600.

# Secret used to verify BTCPay Server webhook signatures (BTCPay-Sig header).
# Generate with: openssl rand -hex 32 — then paste the SAME value into
# BTCPay -> Store -> Settings -> Webhooks when creating the webhook for
# https://<your LS_PREMIUM host>, e.g. https://premium.example.org.
BTCPAY_WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# The Stripe webhook signing secret is NOT set here — it lives in stripe.env
# (STRIPE_WEBHOOK_SECRET), which is loaded after this file. Define it there only,
# so the two files never fight over the same variable.
