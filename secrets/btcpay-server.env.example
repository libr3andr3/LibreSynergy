# btcpay-server.env — internal credentials for the BTCPay unit (profile: btcpay).
# Auto-filled by ./bin/ls init (gen-secrets.sh). bin/ls sources this file so
# the values interpolate into compose/55-btcpay.yml — nothing here is exposed
# outside the compose network. Distinct from btcpay.env, which holds the store
# API key the payments bridge uses.
BTCPAY_PG_PASSWORD=rand_hex_16
BTCPAY_BTC_RPC_USER=btcpayrpc
BTCPAY_BTC_RPC_PASSWORD=rand_hex_16
