# btcpay.env — BTCPay Server credentials for payments-bridge
# Copy to ${LS_SECRETS_DIR}/btcpay.env and fill in real values. chmod 600.

# Base URL of your BTCPay Server (the ${LS_PAY} site, e.g. https://btcpay.example.org).
# Note: compose does not interpolate variables inside env files — write the literal URL.
BTCPAY_URL=https://btcpay.example.org

# Greenfield API key: BTCPay -> Account -> Manage API keys (grant invoice view/create on your store).
BTCPAY_API_KEY=replace_me

# Store ID: BTCPay -> your store -> Settings -> General -> Store ID.
BTCPAY_STORE_ID=replace_me
