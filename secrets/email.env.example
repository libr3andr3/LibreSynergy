# LibreSynergy — SMTP settings for authentik (password resets, invites, notifications)
# Copy to ${LS_SECRETS_DIR}/email.env, fill in your SMTP provider's values, chmod 600.
# authentik works without email, but self-service recovery and invitations need it.

# SMTP server hostname
AUTHENTIK_EMAIL__HOST=smtp.example.org

# 587 = STARTTLS (pairs with USE_TLS=true below); 465 = implicit TLS (use AUTHENTIK_EMAIL__USE_SSL=true instead)
AUTHENTIK_EMAIL__PORT=587

# SMTP login (often the full mailbox address)
AUTHENTIK_EMAIL__USERNAME=sso@example.org

# SMTP password or provider app-password
AUTHENTIK_EMAIL__PASSWORD=REPLACE_WITH_SMTP_PASSWORD

# From address shown to users — e.g. sso@<your LS_BASE_DOMAIN>
AUTHENTIK_EMAIL__FROM=sso@example.org

# STARTTLS on port 587. For port 465 set this to false and add AUTHENTIK_EMAIL__USE_SSL=true.
AUTHENTIK_EMAIL__USE_TLS=true
