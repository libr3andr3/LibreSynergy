# events.env — Matrix event announcer configuration
# Copy to ${LS_SECRETS_DIR}/events.env and fill in real values. chmod 600.
# (Matrix credentials come from matrix.env, which the events service also loads.)

# Internal Matrix room ID where events are announced. Find it in Element:
# Room settings -> Advanced -> "Internal room ID" (starts with '!').
EVENTS_ANNOUNCE_ROOM=!replace_me:matrix.example.org
