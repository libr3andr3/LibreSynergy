# Frappe LMS secrets — copy to ${LS_SECRETS_DIR}/frappe.env and fill in real values.
# Password for the Frappe "Administrator" account, set once at first site creation.
# generate: openssl rand -hex 24
ADMIN_PASSWORD=CHANGE_ME

# API credentials for a Frappe user allowed to manage LMS enrollments
# (used by membership-sync to gate paid courses; leave empty to disable gating).
# Generate in Frappe: user -> Settings -> API Access -> Generate Keys.
FRAPPE_API_KEY=
FRAPPE_API_SECRET=
