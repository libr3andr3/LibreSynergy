# LibreSynergy — Jitsi Meet internal XMPP credentials
# Copy to ${LS_SECRETS_DIR}/jitsi.env and replace every CHANGE_ME value.
# Never commit the real file; chmod 600 it. All four jitsi-* services in
# compose/40-meet.yml load this same file.
#
# Generate each value independently:  openssl rand -hex 16
# Note: Docker Compose interpolates env files — if a value ever contains a
# literal "$", write it as "$$".

# Jicofo (conference focus) component secret + XMPP auth password
JICOFO_COMPONENT_SECRET=CHANGE_ME_openssl_rand_hex_16
JICOFO_AUTH_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# Videobridge XMPP auth password
JVB_AUTH_PASSWORD=CHANGE_ME_openssl_rand_hex_16

# Jigasi (dial-in SIP gateway) XMPP password — unused until you add a jigasi
# service, but harmless to set now
JIGASI_XMPP_PASSWORD=CHANGE_ME_openssl_rand_hex_16
