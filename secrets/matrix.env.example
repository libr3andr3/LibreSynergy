# LibreSynergy — Matrix secrets (copy to ${LS_SECRETS_DIR}/matrix.env, chmod 600)

# Lets admins create accounts while public registration stays closed
# (used by `register_new_matrix_user` and provisioning scripts).
# Generate: openssl rand -hex 32
SYNAPSE_REGISTRATION_SHARED_SECRET=REPLACE_WITH_openssl_rand_hex_32

# Access token of the community bot account; consumed by the
# membership_sync and events services (payments profile).
# Generate: create the bot user, then log in via the client-server API, e.g.
#   curl -s -XPOST https://<LS_MATRIX>/_matrix/client/v3/login \
#     -d '{"type":"m.login.password","identifier":{"type":"m.id.user","user":"bot"},"password":"..."}'
# and copy the "access_token" field from the response.
MATRIX_BOT_TOKEN=REPLACE_WITH_bot_access_token
