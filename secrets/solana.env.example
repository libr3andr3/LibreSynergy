# solana.env — USDC-on-Solana checkout for payments-bridge (optional).
# Copy to ${LS_SECRETS_DIR}/solana.env and fill in to ENABLE. All three of
# RPC_URL + MERCHANT_ADDRESS + USDC_MINT must be set or the feature stays off.
# Non-custodial: only a public receiving address lives here — no private keys.
# chmod 600.

# Hosted RPC endpoint (Helius/Alchemy/QuickNode). Public endpoints are rate-limited;
# use a keyed endpoint for production. Mainnet example: https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
SOLANA_RPC_URL=

# devnet | mainnet-beta  (label shown on the pay page; use mainnet-beta for real money)
SOLANA_NETWORK=mainnet-beta

# Your Solana wallet address that receives USDC (base58 pubkey). Spend keys stay OFFLINE.
SOLANA_MERCHANT_ADDRESS=

# USDC SPL mint. Mainnet USDC: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
SOLANA_USDC_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v

# Watcher poll interval (seconds)
SOLANA_POLL_SECONDS=10
