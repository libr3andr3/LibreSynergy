# stripe.env — Stripe credentials for payments-bridge
# Copy to ${LS_SECRETS_DIR}/stripe.env and fill in real values. chmod 600.

# Secret API key: Stripe Dashboard -> Developers -> API keys (use sk_test_... while testing).
STRIPE_SECRET_KEY=sk_live_replace_me

# Webhook signing secret: Stripe Dashboard -> Developers -> Webhooks -> add an endpoint
# pointing at your bridge on https://<your LS_PREMIUM host> (e.g. https://premium.example.org),
# then copy its "Signing secret".
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Recurring Price ID of the premium membership product: Dashboard -> Products -> your product -> Pricing.
STRIPE_PRICE_ID=price_replace_me
